{
  "appId": "com.podcats.app",
  "productName": "Podcats",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "dist",
      "to": "dist"
    },
    {
      "from": "build-resources/icon.png",
      "to": "icon.png"
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      "dmg"
    ],
    "darkModeSupport": true,
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "icon": "build-resources/icon.icns"
  },
  "win": {
    "icon": "build-resources/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  },
  "dmg": {
    "title": "Podcats",
    "window": {
      "width": 540,
      "height": 380
    },
    "contents": [
      {
        "x": 150,
        "y": 200,
        "type": "file"
      },
      {
        "x": 390,
        "y": 200,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "asar": true
}
